# Copy this file to ".env" and fill in real values.
# NEVER share your actual .env file or commit it to a public place —
# it contains secrets.
#
# IMPORTANT: This server uses Node's built-in SQLite support, which
# requires Node.js version 22 or newer. Run "node -v" to check — if
# it shows v22, v23, v24, or higher, you're fine.

# A long random string used to sign login sessions. Make up any
# long random text here (e.g. mash your keyboard for 40 characters).
JWT_SECRET=replace-this-with-a-long-random-string

# The URL of your actual live website (e.g. https://vi-microsystems.netlify.app)
# Once you know this, put it here instead of using * (which allows any site).
ALLOWED_ORIGIN=*

# --- Email sending (for enquiry form notifications) ---
# GMAIL_USER: the Gmail address you want enquiries sent FROM
# GMAIL_APP_PASSWORD: a special 16-character "App Password" from Google
#   (NOT your normal Gmail password). Steps to create one are in
#   DEPLOYMENT_GUIDE.md.
# NOTIFY_EMAIL: the email address that should RECEIVE enquiry notifications
#   (can be the same as GMAIL_USER, or a different inbox you check)
GMAIL_USER=
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL=

# Port the server runs on. Most hosting services set this automatically;
# you usually don't need to change this.
PORT=3000
